OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMOTION_REPLY_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_SECONDS=20.0
EMOTION_REPLY_TIMEOUT_SECONDS=2.0
RAG_TOP_K=5

NGINX_HOST_PORT=8080
API_WORKERS=1
ASYNC_QUERY_ENABLED=true
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_NAME=support.tasks
EVENT_BUS_CHANNEL=support.events
SENTIMENT_PROVIDER=model
SENTIMENT_MODEL_ID=j-hartmann/emotion-english-distilroberta-base
SENTIMENT_MIN_CONFIDENCE=0.45

TICKET_DB_DSN=postgresql://support:support@postgres:5432/support
TICKET_DB_SCHEMA=public
PGVECTOR_DSN=postgresql://support:support@postgres:5432/support
PGVECTOR_TABLE=docagent_chunks
